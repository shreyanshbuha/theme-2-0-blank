<section class="user-section space">
  <div class="container">
    <div class="user-cover" style="text-align: center;
    margin: 108px 0;">
      <div class="user-inner-box bgcolor4">
        {% comment %}
          This form must use 'reset_customer_password'
        {% endcomment %}
        {% form 'reset_customer_password' %}
          <div class="section-header">
            <h1 class="section-header__title">{{ 'customer.reset_password.title' | t }}</h1>
          </div>

          <p>{{ 'customer.reset_password.subtext' | t: email: email }}</p>

          {{ form.errors | default_errors }}
          <div class="form-wrap" style="margin-top: 35px;">
            <label for="ResetPassword" class="hidden">{{ 'customer.reset_password.password' | t }}</label>
            <input
              type="password"
              placeholder="{{ 'customer.reset_password.password' | t }}"
              value=""
              name="customer[password]"
              id="ResetPassword"
              {% if form.errors contains 'password' %}
                class="error"
              {% endif %}
            >
          </div>
          <div class="form-wrap" style="margin: 18px 0 60px 0;">
            <label for="PasswordConfirmation" class="hidden">
              {{- 'customer.reset_password.password_confirm' | t -}}
            </label>
            <input
              type="password"
              value=""
              placeholder="{{ 'customer.reset_password.password_confirm' | t }}"
              name="customer[password_confirmation]"
              id="PasswordConfirmation"
              {% if form.errors contains 'password_confirmation' %}
                class="error"
              {% endif %}
            >
          </div>
          <p>
            <input type="submit" class="btn" value="{{ 'customer.reset_password.submit' | t }}">
          </p>
        {% endform %}
      </div>
    </div>
  </div>
</section>
