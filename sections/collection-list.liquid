<section class="best-seller-section overflow-hidden space" data-section="Collection">
  <div class="best-seller-section-inner offset-left">
    {% if section.settings.heading != blank %}
      <div class="section-title">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    {% render 'breadcrumbs' %}

    {% if section.blocks.size > 0 %}
      <div style="display:flex;flex-wrap:wrap;">
        {% for block in section.blocks %}
          {% if block.settings.collection.url != blank
            and block.settings.collection.title != blank
            or block.settings.collection.featured_image != blank
          %}
            <div style="background-color:#ebebeb; margin:20px; padding:20px" {{ block.shopify_attributes }}>
              <h3>
                <a href="{{ block.settings.collection.url }}">
                  {{- block.settings.collection.title }}
                  {{ block.settings.collection.featured_image | image_url: width: 200, height: 200 | image_tag -}}
                </a>
              </h3>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    {% else %}
      {% if collections != blank %}
        {% paginate collections by section.settings.range %}
          <div style="display:flex; flex-wrap:wrap; ">
            {% for collection in collections %}
              <div style="background-color:#ebebeb; margin:20px; padding:20px">
                <strong>{{- collection.title | link_to: collection.url }}</strong>
                {{ collection.image | image_url: width: 200, height: 200 | image_tag }}
              </div>
            {% endfor %}
          </div>
          {% render 'pagination', paginate: paginate %}
        {% endpaginate %}
      {% endif %}
    {% endif %}
  </div>

</section>

{% schema %}
{
  "name": "All Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "range",
      "label": "Show Collection",
      "min": 1,
      "max": 10,
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "All collection"
    }
  ]
}
{% endschema %}
