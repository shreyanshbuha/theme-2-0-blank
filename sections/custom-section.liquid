<section class="nested-wrapper">
  {% content_for 'blocks' %}
</section>

<style>
   .tree-item {
    position: relative;
    padding: 12px 16px;
    margin: 6px 0;
    background: #f3f3f3;
    border-radius: 6px;
    border: 1px solid #e5e5e5;
    cursor: pointer;
    transition: 0.3s ease;
    display: none;
  }

  .level-1 {
    display: block;
    margin-left: 0;
    background:#e0e0e0;
    font-weight:600;
  }

  .level-2 { margin-left: 30px; }
  .level-3 { margin-left: 60px; }
  .level-4 { margin-left: 90px; }
  .level-5 { margin-left: 120px; }
  .level-6 { margin-left: 150px; }

  .tree-item::before {
    content: "▶";
    position: absolute;
    left: -18px;
    font-size: 11px;
    transition: 0.3s ease;
  }

  .tree-item.open::before {
    transform: rotate(90deg);
  }

  .tree-item.no-child::before {
    content: "";
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const items = document.querySelectorAll('.tree-item');

    function getLevel(el) {
      const match = el.className.match(/level-(\d+)/);
      return match ? parseInt(match[1]) : 0;
    }

    items.forEach((item, index) => {
      const level = getLevel(item);
      let hasChild = false;

      for (let i = index + 1; i < items.length; i++) {
        const nextLevel = getLevel(items[i]);

        if (nextLevel === level + 1) {
          hasChild = true;
          break;
        }

        if (nextLevel <= level) {
          break;
        }
      }

      if (!hasChild) {
        item.classList.add('no-child');
      }

      item.addEventListener('click', function (e) {
        e.stopPropagation();

        if (!hasChild) return;

        const isOpen = item.classList.contains('open');
        item.classList.toggle('open');

        for (let i = index + 1; i < items.length; i++) {
          const nextLevel = getLevel(items[i]);

          if (nextLevel <= level) break;

          if (isOpen) {
            items[i].style.display = 'none';
            items[i].classList.remove('open');
          } else if (nextLevel === level + 1) {
            items[i].style.display = 'block';
          }
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Nested Menu",
  "tag": "section",
  "class": "section-nested-menu",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Nested Menu",
      "blocks": [{ "type": "nested-parent" }]
    }
  ]
}
{% endschema %}
