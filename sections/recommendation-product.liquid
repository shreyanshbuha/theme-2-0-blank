<script src="{{ 'recommendation.js' | asset_url }}" defer></script>
<div class="container" style="margin-bottom:30px;">
  <div
    class="product-recommendations"
    data-url="{{ routes.product_recommendations_url }}?product_id={{ product.id }}&limit={{ section.settings.limit }}&section_id=recommendation-product&intent=related"
  >
    {% if section.settings.heading != blank %}
      <div class="section-title text-center">
        <h2>
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}
    {% if recommendations.performed? %}
      {% if recommendations.products_count > 0 %}
        <div class="desk_only_slider product-row" style="display:flex;">
          {% for product in recommendations.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% render 'recommendation' %}

{% schema %}
{
  "name": "Recommendation Product",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Recommendat Product Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Product Limit",
      "min": 1,
      "max": 10,
      "default": 1
    },
  ],
  "presets": [
    {
      "name": "Recommendation Product"
    }
  ]
}
{% endschema %}
