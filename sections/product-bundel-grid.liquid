{% if section.settings.productlist != blank %}
  <div class="container">
    <div
      class="products-wrapper"
      style="display:flex;flex-wrap:wrap;gap:20px; margin-top:100px;"
      data-section="Product Bundel Grid"
    >
      {% for this_product in section.settings.productlist %}
        <div style="display:flex;">
          <div
            class="product-card"
            data-variant-id="{{ this_product.selected_or_first_available_variant.id }}"
            style="display: block !important;"
          >
            {% render 'product-card', product: this_product %}

            <button type="button" class="qty-minus" style="padding:3px 10px;">-</button>
            <input
              type="number"
              class="qty-input"
              value="1"
              min="1"
              style="width:60px;text-align:center;"
            >
            <button type="button" class="qty-plus" style="padding:3px 10px;">+</button>
          </div>
        </div>
      {% endfor %}
    </div>

    <button
      class="cart-btn"
      id="add-all-btn"
      style="margin-top:20px;"
    >
      All Add to Cart
    </button>
  </div>
{% else %}
  <h5 style="text-align: center; margin: 275px 0;">No any bundel exiest</h5>
{% endif %}

<style>
  .best-sell-item .wk-button{
  left: 0px !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.product-card').forEach((card) => {
      let minusBtn = card.querySelector('.qty-minus');
      let plusBtn = card.querySelector('.qty-plus');
      let input = card.querySelector('.qty-input');

      if (!minusBtn || !plusBtn || !input) {
        return;
      }

      minusBtn.addEventListener('click', () => {
        if (input.value > 1) input.value--;
      });

      plusBtn.addEventListener('click', () => {
        input.value++;
      });
    });

    document.getElementById('add-all-btn').addEventListener('click', function () {
      let items = [];

      document.querySelectorAll('.product-card').forEach((card) => {
        let variantId = card.dataset.variantId;
        let input = card.querySelector('.qty-input');

        if (!variantId || !input) return;

        items.push({
          id: parseInt(variantId),
          quantity: parseInt(input.value),
        });
      });

      fetch('/cart/add.js', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify({ items, sections: ['cart-drawer', 'main-cart'] }),
      })
        .then((res) => res.json())
        .then((data) => {
          getCartData(data);
        })
        .catch((err) => {
          console.error(err);
        });
    });
  });
</script>

{% schema %}
{
  "name": "Bundel Product",
  "settings": [
    {
      "type": "product_list",
      "id": "productlist",
      "label": "Product List"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Bundel Product"
    }
  ]
}
{% endschema %}
