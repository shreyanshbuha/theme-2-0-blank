{% if section.settings.heading.size > 0 %}
  <div class="mission-third-section">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <div class="container">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p>{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
{% endif %}

{% style %}
  .mission-third-section
  {
      background-image: url({{ 'pattern-bg.jpeg' | asset_url }})
  }
  @media screen and (max-width: 767px) {
      .mission-third-section
      {
          background-image: url({{ 'pattern-mobile.jpeg' | asset_url }})
      }
  }
{% endstyle %}

{% schema %}
{
  "name": "Mission Premium Swiss",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Premium Swiss Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Premium Swiss Description"
    }
  ],
  "presets": [
    {
      "name": "Mission Premium Swiss"
    }
  ]
}
{% endschema %}
